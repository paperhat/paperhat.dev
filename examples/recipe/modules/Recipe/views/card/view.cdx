<View id="recipe:card">
	<Text source="Title" />
	<Text source="Summary" />

	<Group name="QuickFactsItems">
		<Item source="Servings" />
		<Item source="PreparationTime" />
		<Item source="CookingTime" />
	</Group>

	<UnorderedList
		name="IngredientsList"
		source="Ingredients"
	>
		<Item name="IngredientsItem">
			<Text source="name" />
			<Text source="amount" />
			<Text source="unit" />

			<Flag name="Optional" when="optional" />
		</Item>
	</UnorderedList>
</View>
